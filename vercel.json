{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": false
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.vbcoding.cc/:path*"
    },
    {
      "source": "/v1/:path*",
      "destination": "https://api.vbcoding.cc/v1/:path*"
    }
  ]
}
